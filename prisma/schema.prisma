generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Supervisor {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // Will store the bcrypt hash
  name      String
  createdAt DateTime @default(now())
}

model Worker {
  id        Int      @id @default(autoincrement())
  name      String
  deviceId  String   @unique // The physical ESP32 Serial
  status    String   @default("green") // 'green' or 'red'
  role      String   
  lastSeen  DateTime @default(now())
  
  logs      HealthLog[]
}

model HealthLog {
  id        Int      @id @default(autoincrement())
  timestamp DateTime @default(now())
  heartRate Float
  skinTemp  Float
  riskLevel Int      // 0 or 1
  tc        Int      @default(5) // Thermal Comfort: 5 (Low), 11 (Medium), 17 (High)
  workerId  Int
  worker    Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([timestamp])
  @@index([workerId])
}